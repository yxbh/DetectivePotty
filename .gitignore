# --- DetectivePotty ---
# Captured/sample video, frames, and generated event dataset (kept local for now)
data/
dataset/
dataset.pre-reset-*/
outputs/

# Local, secret-bearing config (NVR creds, API keys, RTSP tokens)
*.local.yaml
*.local.yml
.env
.env.*
secrets/

# --- macOS ---
.DS_Store

# --- Python / uv ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# --- Models / weights (downloaded at runtime) ---
*.pt
*.onnx
*.engine
*.mlpackage
*.mlmodel

# Curated, committable CoreML exports live here (negate the *.mlpackage ignore
# above so a minimal set can be checked in without `git add -f`).
!models/coreml/
!models/coreml/**

# Frontend build artifacts (built on demand, not committed)
src/detectivepotty/web/frontend/node_modules/
src/detectivepotty/web/frontend/dist/
